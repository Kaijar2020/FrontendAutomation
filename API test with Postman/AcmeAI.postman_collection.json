    {
      "name": "SerachWithTitle",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Response is valid JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "\r",
              "\r",
              "pm.test(\"Success flag is true\", function () {\r",
              "    pm.expect(jsonData.success).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.test(\"Message is correct\", function () {\r",
              "    pm.expect(jsonData.message).to.eql(\"Search completed successfully\");\r",
              "});\r",
              "\r",
              "pm.test(\"Data object exists\", function () {\r",
              "    pm.expect(jsonData.data).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"Summary exists and is a string\", function () {\r",
              "    pm.expect(jsonData.data.summary).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.data.summary.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Matched docs is a non-empty array\", function () {\r",
              "    pm.expect(jsonData.data.matched_docs).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.data.matched_docs.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Document structure is valid\", function () {\r",
              "    const doc = jsonData.data.matched_docs[0];\r",
              "\r",
              "    pm.expect(doc).to.have.property(\"id\");\r",
              "    pm.expect(doc).to.have.property(\"title\");\r",
              "    pm.expect(doc).to.have.property(\"content\");\r",
              "\r",
              "    pm.expect(doc.id).to.be.a(\"number\");\r",
              "    pm.expect(doc.title).to.be.a(\"string\");\r",
              "    pm.expect(doc.content).to.be.a(\"string\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
